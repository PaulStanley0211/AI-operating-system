# CRAFT AIOS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with 'repo' scope. Used by /push.
GITHUB_TOKEN=

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Required for the Telegram bot (worker.py)
ANTHROPIC_API_KEY=

# ── Google / Gemini ──────────────────────────────────────────────────────────
# Used by Coffee Debrief Node for brief generation (cheapest option)
GEMINI_API_KEY=

# ── YouTube Data API v3 ──────────────────────────────────────────────────────
# Get from console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use a restricted key with read-only permissions
STRIPE_SECRET_KEY=

# ── Gmail (OAuth2) ───────────────────────────────────────────────────────────
# Run reach/auth/gmail_auth.py once to generate token.json
GMAIL_CREDENTIALS_PATH=reach/auth/gmail_credentials.json
GMAIL_TOKEN_PATH=reach/auth/token.json

# ── Outlook / Microsoft 365 ──────────────────────────────────────────────────
# Azure AD app registration. Run reach/auth/outlook_auth.py once.
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=

# ── Fireflies ─────────────────────────────────────────────────────────────────
FIREFLIES_API_KEY=

# ── Open Exchange Rates (FX) ─────────────────────────────────────────────────
# Free tier: 1000 calls/month — sufficient for daily collection
OPEN_EXCHANGE_RATES_APP_ID=

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get bot token from @BotFather. Get chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated list of allowed chat IDs (security allowlist)
TELEGRAM_CHAT_ID_ALLOWLIST=

# ── OpenAI (Whisper) ─────────────────────────────────────────────────────────
# Used for voice note transcription in the Telegram bot
OPENAI_API_KEY=

# ── Brief Configuration ───────────────────────────────────────────────────────
# LLM to use for brief generation: 'gemini' or 'claude'
BRIEF_LLM=gemini
# Brief preset: 'founder' (short, high-level) or 'operator' (detailed)
BRIEF_PRESET=founder
# Primary metric to chart in the dashboard image: 'youtube_subscribers', 'mrr', etc.
DASHBOARD_METRIC=youtube_subscribers

# ── Bot Configuration ─────────────────────────────────────────────────────────
# Bot persona: 'executive', 'analyst', or 'assistant'
BOT_PERSONA=assistant
